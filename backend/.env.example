# Example format: postgresql+psycopg://user:password@host:5432/db_name
API_KEY_01_DATABASE_URL=DUMMY_REPLACE_WITH_DATABASE_URL

# Example format: a long random string, min 32 chars
API_KEY_02_JWT_SECRET=DUMMY_REPLACE_WITH_STRONG_JWT_SECRET

# Example format: https://<project-ref>.supabase.co
API_KEY_03_SUPABASE_URL=DUMMY_REPLACE_WITH_SUPABASE_URL

# Example format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
API_KEY_04_SUPABASE_SERVICE_ROLE_KEY=DUMMY_REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
